# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Node dependencies (reinstalled inside Docker) ────────────────────────────
node_modules
**/node_modules

# ── Build outputs (rebuilt inside Docker) ────────────────────────────────────
**/dist
!lib/api-spec

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.local

# ── Database dumps (not needed in image) ─────────────────────────────────────
backup.sql
backup2.sql
*.sql.gz
*.dump

# ── Editor & OS artefacts ─────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Test files ────────────────────────────────────────────────────────────────
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js
**/__tests__
**/__mocks__

# ── Replit-specific ───────────────────────────────────────────────────────────
.replit
replit.nix
.upm
.cache
.local
.agents

# ── CI / misc docs ────────────────────────────────────────────────────────────
.github
.husky
DEPLOYMENT_GUIDE.md

# ── pnpm store cache ──────────────────────────────────────────────────────────
.pnpm-store
